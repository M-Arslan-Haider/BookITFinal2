<?xml version="1.0" encoding="utf-8"?>
<!--
    network_security_config.xml
    Place at: android/app/src/main/res/xml/network_security_config.xml

    Android 9+ blocks ALL cleartext (non-HTTPS) traffic in release builds.
    Your MQTT broker at 119.153.102.7:1883 uses plain TCP — must be whitelisted.
    Your REST API at cloud.metaxperts.net uses HTTPS — no change needed for that.

    ✅ FIX: The original file only had a <domain-config> block.
    That means ONLY traffic TO 119.153.102.7 was allowed cleartext.
    All OTHER traffic (Firebase, Play Services) was not explicitly permitted,
    which can cause failures on strict devices.
    The base-config below restores Android's default behaviour for all other hosts
    while keeping the MQTT broker whitelisted.
-->
<network-security-config>

    <!-- Default for all connections: honour Android's standard rules (HTTPS required for release) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- ✅ Allow plain TCP to your MQTT broker (port 1883, no TLS) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">119.153.102.7</domain>
    </domain-config>

    <!--
        If your REST API server (cloud.metaxperts.net:8443) uses a self-signed
        or private CA certificate, uncomment and fill in the cert below.
        Otherwise leave this commented — public HTTPS works fine without it.

    <domain-config>
        <domain includeSubdomains="true">cloud.metaxperts.net</domain>
        <trust-anchors>
            <certificates src="@raw/my_ca_cert" />
        </trust-anchors>
    </domain-config>
    -->

</network-security-config>